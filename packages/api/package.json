{
  "name": "@closepilot/api",
  "version": "0.1.0",
  "private": true,
  "description": "Hono-based REST API",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
