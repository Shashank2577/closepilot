# ─────────────────────────────────────────────────────────────────────────────
# Closepilot — Environment Variables
#
# FREE STACK:
#   DATABASE_URL  → Neon (neon.tech, free tier, pgvector included)
#   REDIS_URL     → Redis Cloud (redis.io, free 30 MB, scripting supported)
#   Web frontend  → Vercel (vercel.com, free hobby tier)
#   API + Worker  → Oracle Cloud VPS or Fly.io (3 free machines)
#
# LOCAL STACK (docker-compose up):
#   Use the defaults below — postgres + redis run inside Docker.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker:  postgresql://closepilot:closepilot_dev@localhost:5432/closepilot
# Neon (prod):   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://closepilot:closepilot_dev@localhost:5432/closepilot

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker:  redis://localhost:6379
# Redis Cloud:   redis://default:password@redis-xxxxx.ec2.cloud.redislabs.com:12345
# (TLS variant): rediss://default:password@redis-xxxxx.ec2.cloud.redislabs.com:12345
REDIS_URL=redis://localhost:6379

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Create at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (user sign-in + Gmail/Drive access) ─────────────────────────
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:3002/auth/callback (dev)
#                            https://your-domain.com/auth/callback (prod)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3002/auth/callback

# ── Google OAuth runtime tokens (set after first sign-in via the app) ─────────
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# ── Google Service Account (Drive/Docs server-side proposal generation) ───────
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ── JWT / Session ─────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=change_this_to_a_random_32_char_string

# ── API server ────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ── Frontend (Vercel sets this automatically) ─────────────────────────────────
# Local: http://localhost:3001 (Next.js proxy rewrites /api/* to this)
# Prod:  https://closepilot-api.fly.dev  (or your VPS domain)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── CRM Integrations (configure the one you use) ─────────────────────────────
CRM_TYPE=hubspot   # hubspot | salesforce | pipedrive

HUBSPOT_API_KEY=
HUBSPOT_OAUTH_TOKEN=

SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

PIPEDRIVE_API_KEY=

# ── Orchestrator ──────────────────────────────────────────────────────────────
APPROVER_EMAIL=owner@yourcompany.com
NOTIFICATION_WEBHOOK=   # Optional: Slack incoming webhook URL for deploy alerts

# ── Google Drive ──────────────────────────────────────────────────────────────
PROPOSAL_TEMPLATE_ID=   # Google Docs template file ID for proposal generation
