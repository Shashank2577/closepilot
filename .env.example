# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://closepilot:closepilot_dev@localhost:5432/closepilot

# ── Google OAuth (web app sign-in) ─────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3002/auth/callback

# ── Google OAuth runtime tokens (set after first sign-in) ──────────────────
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# ── Google Service Account (Drive / Docs server-side operations) ────────────
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ── Anthropic Claude API ────────────────────────────────────────────────────
# Create at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_random_32_char_string

# ── API server ──────────────────────────────────────────────────────────────
API_PORT=3001

# ── CRM integrations (configure the one you use) ───────────────────────────
CRM_TYPE=hubspot   # hubspot | salesforce | pipedrive

# HubSpot
HUBSPOT_API_KEY=
HUBSPOT_OAUTH_TOKEN=

# Salesforce
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# Pipedrive
PIPEDRIVE_API_KEY=

# ── Orchestrator ─────────────────────────────────────────────────────────────
APPROVER_EMAIL=owner@yourcompany.com
NOTIFICATION_WEBHOOK=   # Optional: Slack incoming webhook URL

# ── Google Drive ─────────────────────────────────────────────────────────────
PROPOSAL_TEMPLATE_ID=   # Google Docs template file ID

# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development
